# Postgres Configuration
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas_password
POSTGRES_DB=atlas_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Computed database URL for SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
# URL for Alembic (synchronous)
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
